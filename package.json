{
  "name": "botvinnik-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:brain": "esbuild brain/brain-entry.ts --bundle --format=iife --global-name=brain --platform=browser --outfile=flutter/assets/brain.js && node scripts/smoke-brain.mjs && node scripts/replay-fixtures.mjs && npm run build:maia-brain",
    "build:maia-brain": "esbuild flutter/native_src/maia-brain.ts --bundle --format=iife --global-name=maiaBrain --platform=browser --target=es2022 --outfile=flutter/assets/maia-brain.js && node scripts/smoke-maia-brain.mjs",
    "check": "tsc -p tsconfig.json",
    "check:flutter-ts": "tsc -p flutter/tsconfig.json",
    "fixtures": "tsx scripts/emit-golden-fixtures.mts",
    "fixtures:maia": "tsx scripts/emit-maia-brain-fixtures.mts",
    "test": "vitest run",
    "test:e2e:flutter": "playwright test -c flutter/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "onnxruntime-web": "1.27.0",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "js-chess-engine": "2.4.6"
  },
  "license": "GPL-3.0-or-later"
}
