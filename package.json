{
  "name": "botvinnik-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:brain": "esbuild brain/brain-entry.ts --bundle --format=iife --global-name=brain --platform=browser --outfile=flutter/assets/brain.js && node scripts/smoke-brain.mjs && node scripts/replay-fixtures.mjs",
    "build:maia-brain": "esbuild flutter/native_src/maia-brain.ts --bundle --format=iife --global-name=maiaBrain --platform=browser --target=es2022 --outfile=flutter/assets/maia-brain.js",
    "check:flutter-ts": "tsc -p flutter/tsconfig.json",
    "fixtures": "tsx scripts/emit-golden-fixtures.mts",
    "preview": "vite preview",
    "test": "vitest run",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:setup": "mkdir -p svelte/src-tauri/binaries && cp \"$(which stockfish)\" svelte/src-tauri/binaries/stockfish-aarch64-apple-darwin",
    "test:rust": "cargo test --manifest-path svelte/src-tauri/Cargo.toml",
    "test:e2e:tauri": "node scripts/e2e-tauri.mjs",
    "test:e2e": "playwright test",
    "test:e2e:flutter": "playwright test -c flutter/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "onnxruntime-web": "1.27.0",
    "playwright": "^1.61.1",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "chess.js": "^1.4.0",
    "chessground": "^9.2.1",
    "js-chess-engine": "2.4.6",
    "stockfish": "^18.0.8",
    "stockfish.wasm": "^0.10.0"
  },
  "license": "GPL-3.0-or-later"
}
