<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- No app-sandbox: botvinnik runs external UCI engine binaries (#183),
	     which a sandboxed app cannot exec ("Operation not permitted"). Direct
	     distribution only; notarization needs the hardened runtime + signing,
	     not the sandbox. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- flutter_secure_storage (#203 sync) writes the sync session to the
	     Keychain. Even un-sandboxed, macOS rejects Keychain access without this
	     entitlement (errSecMissingEntitlement, -34018). -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	</array>
</dict>
</plist>
