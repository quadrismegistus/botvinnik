<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- No app-sandbox: botvinnik runs external UCI engine binaries (#183),
	     which a sandboxed app cannot exec ("Operation not permitted"). Direct
	     distribution only; notarization needs the hardened runtime + signing,
	     not the sandbox. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- No keychain-access-groups: it requires a development signing cert this
	     build does not have (#67). SecureSyncKeyStore degrades gracefully when
	     the Keychain is unavailable. Add it back once macOS is signed. -->
</dict>
</plist>
