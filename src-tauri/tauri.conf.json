{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "botvinnik",
  "version": "0.1.0",
  "identifier": "com.ryanheuser.botvinnik",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Botvinnik",
        "width": 1500,
        "height": 1000,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "externalBin": [
      "binaries/stockfish"
    ]
  }
}